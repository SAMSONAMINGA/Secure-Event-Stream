# ─── Copy this file to .env and fill in your values ──────────────────────────
# NEVER commit .env to version control

# ── JWT (required) ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=

# ── Database (required) ────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/transactions
DB_USERNAME=user
DB_PASSWORD=changeme

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions

# ── Fraud Thresholds (optional — defaults shown) ───────────────────────────────
FRAUD_AMOUNT_THRESHOLD=10000
FRAUD_VELOCITY_WINDOW_MINUTES=10
FRAUD_VELOCITY_MAX_COUNT=10
FRAUD_DAILY_VOLUME_CAP=50000

# ── App Users (override defaults in production) ────────────────────────────────
# Replace InMemoryUserDetailsManager with a real UserRepository in prod
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=changeme
APP_USER_USERNAME=user
APP_USER_PASSWORD=changeme

# ── JPA DDL ────────────────────────────────────────────────────────────────────
# Local dev: create-drop   Production: validate (use Flyway/Liquibase instead)
JPA_DDL_AUTO=create-drop

# ── Spring Profile ─────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local

# ── Log Level ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
